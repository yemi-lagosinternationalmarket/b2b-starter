# apps/messaging environment variables.
# Copy to .env (gitignored) and fill in values for local dev.

# Shared Supabase Postgres connection string. All messaging tables live under
# the dedicated `messaging` schema. No migrations run in B.0 (schema is empty).
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Shared-secret API key for service-to-service calls into the messaging API.
# Auth middleware wiring is B.3 (#8); this is documented here so the value is
# available when that lands.
MESSAGING_API_KEY=

# Single-tenant default UUID for v0 / LIM-only operation (ADR 0022).
# Every messaging row is stamped with this tenant_id; SaaS multi-tenant
# (12-18mo) will source tenant_id from the authenticated request instead.
# Generate with `uuidgen` or `python -c "import uuid; print(uuid.uuid4())"`.
# Leave commented in this template — copy to .env and set a real value.
# MESSAGING_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000

# Optional. Fastify bind config.
PORT=4100
HOST=0.0.0.0
LOG_LEVEL=info
